{
  "name": "world-of-scripts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "devpin run --wait",
    "dev:app": "vp dev --host 127.0.0.1",
    "build": "tsc --noEmit && vp build",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "preview": "vp preview --host 127.0.0.1",
    "validate:content": "tsx scripts/validate-content.ts"
  },
  "devpin": {
    "command": [
      "vp",
      "exec",
      "portless",
      "world-of-scripts",
      "vp",
      "dev",
      "--host",
      "127.0.0.1"
    ],
    "env": {
      "PORTLESS_APP_PORT": "{port}"
    },
    "publicUrl": "https://world-of-scripts.localhost"
  },
  "portless": {
    "name": "world-of-scripts",
    "script": "dev:app"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource/noto-sans-mongolian": "^5.2.6",
    "@fontsource/noto-sans-nushu": "^5.2.6",
    "@fontsource/noto-sans-sogdian": "^5.2.6",
    "@fontsource/noto-serif-khitan-small-script": "^5.2.7",
    "@fontsource/noto-serif-old-uyghur": "^5.2.6",
    "@fontsource/noto-serif-tangut": "^5.2.7",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^5.0.0",
    "@xyflow/react": "^12.8.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "radix-ui": "^1.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "vite": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "devpin": "^0.1.1",
    "portless": "^0.15.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite-plus": "catalog:",
    "wrangler": "^4.105.0"
  }
}
